        {"id": "count_n3",  "front": "さん",   "frontSub": "3 · 三",  "back": "three"},
        {"id": "count_n4",  "front": "よん",   "frontSub": "4 · 四",  "back": "four", "notes": "also し — e.g. 四月 (しがつ) April"},
