        {"id": "count_n6",  "front": "ろく",   "frontSub": "6 · 六",  "back": "six"},
        {"id": "count_n7",  "front": "なな",   "frontSub": "7 · 七",  "back": "seven", "notes": "also しち — e.g. 七時 (しちじ) 7 o’clock"},
